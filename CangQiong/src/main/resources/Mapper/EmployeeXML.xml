<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.cangqiong.Mapper.EmployeeMapper">
    <select id="selectEmployeePage" resultType="com.example.cangqiong.Pojo.EmployeeBody">
        select * from employee
            <where>
                <if test="p.name != null and p.name != '' ">
                     name like concat('%',#{p.name},'%')
                </if>
            </where>
        limit #{start} , #{p.pageSize}
    </select>
</mapper>


